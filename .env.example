# 운영 배포용 .env 템플릿 — 실제 값은 호스팅 비밀 관리에 저장하세요.
# 모든 시크릿은 `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"` 로 새로 발급.

# DB
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# 보안 시크릿 (32자 이상 랜덤 hex)
JWT_SECRET=""
ENCRYPTION_KEY=""           # 정확히 64자 hex (32바이트)
SCHEDULER_SECRET=""

# Claude API
ANTHROPIC_API_KEY=""

# 앱 URL (반드시 https://...)
NEXT_PUBLIC_APP_URL="https://your-domain.example"
NEXT_PUBLIC_BASE_URL="https://your-domain.example"

# OAuth (사용 시)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
